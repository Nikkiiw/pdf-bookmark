{
  "name": "obsidian-pdf-bookmark",
  "version": "0.2.0",
  "description": "Browse PDF bookmarks and insert links that stay valid when PDFs are updated.",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "version": "node version-bump.mjs && git add manifest.json versions.json"
  },
  "keywords": ["obsidian", "pdf", "bookmark", "outline", "link"],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.11.0",
    "esbuild": "^0.20.0",
    "obsidian": "latest",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "pdfjs-dist": "3.11.174"
  }
}
